{
  "name": "ui5uploadcontrols",
  "version": "1.0.0",
  "devDependencies": {
    "@ui5/cli": "^4.0.33",
    "karma": "^6.3.17",
    "karma-chrome-launcher": "^3.1.1",
    "karma-cli": "^2.0.0",
    "karma-ui5": "^3.0.3",
    "@sap/ux-ui5-tooling": "1",
    "@sapui5/types": "1.136.0",
    "eslint": "^9",
    "@ui5/ts-interface-generator": "^0.8.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "ui5-tooling-transpile": "^3.10.0",
    "@sap-ux/eslint-plugin-fiori-tools": "^9.0.0"
  },
  "scripts": {
    "build": "run-p -l build-app build-interface",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "start": "fiori run --open \"test-resources/miyasuta/ui5uploadcontrols/Example.html\"",
    "testsuite": "fiori run --open test-resources/miyasuta/ui5uploadcontrols/qunit/testsuite.qunit.html",
    "test": "karma start --browsers=ChromeHeadless --singleRun=true",
    "build-app": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "build-interface": "npx @ui5/ts-interface-generator",
    "ts-typecheck": "tsc --noEmit",
    "lint": "eslint ."
  }
}
